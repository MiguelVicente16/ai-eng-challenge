GOOGLE_API_KEY=your-google-ai-studio-key-here

# Optional: set to enable persistent conversation state across restarts.
# Leave unset to run with in-memory storage (default, zero setup).
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=deus_bank

# Optional — Deepgram speech-to-text and text-to-speech.
# When unset, /chat ignores audio_base64 and /voice returns a 1011 close.
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-2-general
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
